%% title: fig-04 single-agent harness
%% chapter: CH09
%% caption: single-agent harness は init、boundary、permission、verify、exit、report を 1 つの実行枠にまとめる。
flowchart LR
    I[init] --> B[boundary]
    B --> P{permission}
    P -- 不要 --> W[work]
    P -- 必要 --> A[needs-human-approval]
    W --> V{verify}
    V -- fail --> R[retry / narrow scope]
    R --> B
    V -- pass --> E{exit}
    E -- done --> D[done]
    E -- blocked --> X[blocked]
    D --> O[report]
    X --> O
    A --> O
